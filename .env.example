# Database (Neon Postgres or SQLite file path)
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech:5432/neondb?sslmode=require

# Payload CMS — MUST be a random 32+ char secret in production
PAYLOAD_SECRET=your-secret-key-here

# Public site URL (used for SEO, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Blob Storage — required for media uploads
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Cloudflare Turnstile — anti-spam for contact + testimonial forms
# Get keys at https://dash.cloudflare.com/turnstile
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Seed route (dev only) — optional overrides
SEED_ADMIN_EMAIL=admin@instant-tranquille.com
SEED_ADMIN_PASSWORD=
